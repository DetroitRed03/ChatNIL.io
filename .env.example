# ===========================================
# ChatNIL Environment Variables
# ===========================================
# Copy this file to .env.local and fill in values:
#   cp .env.example .env.local

# -------------------------------------------
# Supabase (Required)
# Get from: Supabase Dashboard > Settings > API
# -------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_URL=your_supabase_project_url

# -------------------------------------------
# App Configuration (Required)
# -------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -------------------------------------------
# AI / LLM (Required for chat & document analysis)
# -------------------------------------------
OPENAI_API_KEY=your_openai_api_key

# -------------------------------------------
# Email (Required for notifications & invites)
# Get from: https://resend.com
# -------------------------------------------
RESEND_API_KEY=your_resend_api_key

# -------------------------------------------
# Optional Services
# -------------------------------------------

# Perplexity AI (for enhanced search)
# PERPLEXITY_API_KEY=your_perplexity_api_key

# PostHog Analytics
# NEXT_PUBLIC_POSTHOG_KEY=your_posthog_project_key
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
# POSTHOG_API_KEY=your_posthog_api_key

# Cron job authentication (for scheduled tasks in production)
# CRON_SECRET=your_cron_secret

# Rate limiting salt (defaults to 'chatnil' if not set)
# RATE_LIMIT_SALT=your_random_salt

# Development mode flag
# NEXT_PUBLIC_DEV_MODE=true
